        <item name="colorPrimaryVariant">#3D8ABF</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">#7EC8E3</item>
        <item name="colorSecondaryVariant">#5BA4CF</item>
        <item name="colorOnSecondary">#FF1A3A4C</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
